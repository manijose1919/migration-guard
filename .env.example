# MigrationGuard configuration (copy to .env and adjust).
# SECURITY: never commit a real .env — it is git-ignored on purpose.

# --- API server ---
MG_API_HOST=0.0.0.0
MG_API_PORT=8000

# --- Analysis policy ---
# Minimum severity that causes a non-zero exit code in the CLI / CI gate.
# One of: INFO | LOW | MEDIUM | HIGH | CRITICAL
MG_FAIL_ON=HIGH

# Comma-separated table names you consider "large" / high-traffic.
# Rules escalate severity for operations that lock these tables.
# Example: MG_LARGE_TABLES=users,orders,events
MG_LARGE_TABLES=

# Comma-separated rule IDs to disable (e.g. MG001,MG004).
MG_DISABLED_RULES=
